{
  "name": "@storees/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node -e \"import('node:fs').then(fs=>{fs.cpSync('src/packs','dist/packs',{recursive:true});fs.cpSync('src/db/migrations','dist/db/migrations',{recursive:true})})\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/scripts/seed.ts",
    "db:migrate": "tsx src/scripts/migrate.ts"
  },
  "dependencies": {
    "@shopify/shopify-api": "^11.0.0",
    "@storees/flows": "*",
    "@storees/segments": "*",
    "@storees/shared": "*",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
