    "seed": "tsx src/scripts/seed.ts",
    "db:migrate": "drizzle-kit push"
  },
  "dependencies": {
    "@shopify/shopify-api": "^11.0.0",
    "@storees/flows": "*",
    "@storees/segments": "*",
    "@storees/shared": "*",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
