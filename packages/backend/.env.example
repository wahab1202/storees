# Database
DATABASE_URL=postgresql://user:password@localhost:5432/storees

# Redis
REDIS_URL=redis://localhost:6379

# Shopify App Credentials (from Shopify Partner Dashboard)
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SCOPES=read_products,write_products,read_customers,write_customers,read_orders,write_orders,read_inventory,read_locations,read_product_listings,read_shipping,read_fulfillments,unauthenticated_read_product_listings,unauthenticated_read_customers,unauthenticated_write_customers,unauthenticated_read_checkouts,unauthenticated_write_checkouts,unauthenticated_read_content,unauthenticated_read_product_tags

# Email
RESEND_API_KEY=re_your_resend_api_key

# App URLs
SHOPIFY_APP_URL=http://localhost:3001
SHOPIFY_WEBHOOK_URL=http://localhost:3001/api/webhooks/shopify
MERCHANT_PANEL_URL=http://localhost:3000
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
PORT=3001

# AI (Gemini Flash — free tier from aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Auth
JWT_SECRET=generate_with_openssl_rand_hex_32

# Encryption (for Shopify access tokens at rest)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Demo mode — overrides all flow delay values
DEMO_DELAY_MINUTES=2
